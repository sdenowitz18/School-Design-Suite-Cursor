DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
PORT=5050

# Client build (Vite): when the SPA is on a different host than the API (e.g. Vercel static + Railway API),
# set this to the API origin only — no trailing slash. Example: https://your-app.up.railway.app
# VITE_API_BASE_URL=

# Express API: browser origin allowed to call the API (required for cross-origin SPA). Example:
# CORS_ORIGIN=https://school-design-suite-cursor.vercel.app
# CORS_ORIGIN=*
